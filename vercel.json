{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node", "config": { "includeFiles": ["api/config/certs/isrgrootx1.pem"] } },
    { "src": "sms-frontend/package.json", "use": "@vercel/static-build" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "api/index.js" },
    { "source": "/((?!api/|assets/|[^/]+\\.[^/]+$).*)", "destination": "sms-frontend/index.html" },
    { "source": "/(.*)", "destination": "sms-frontend/$1" }
  ]
}
